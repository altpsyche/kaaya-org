---
interface Props {
  title: string;
  description: string;
  href: string;
}

const { title, description, href } = Astro.props;
---

<a
  href={href}
  class="group block rounded-[--radius-card] border border-[--color-border] bg-[--color-surface] p-6 hover:border-[--color-primary] hover:shadow-md transition-all"
>
  <h3 class="text-lg font-semibold text-[--color-text] group-hover:text-[--color-primary] transition-colors">
    {title}
  </h3>
  <p class="mt-2 text-sm text-[--color-text-muted] leading-relaxed">{description}</p>
  <span class="mt-4 inline-block text-xs font-medium text-[--color-primary]">Explore →</span>
</a>
