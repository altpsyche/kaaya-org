---
import { SITE } from '../../data/site';
import ContactBlock from '../ui/ContactBlock.astro';
import { url } from '../../lib/url';

const year = new Date().getFullYear();
---

<footer class="border-t border-[--color-border] bg-[--color-surface] mt-auto">
  <div class="mx-auto max-w-5xl px-6 py-10">
    <div class="grid gap-8 sm:grid-cols-2">
      <div>
        <p class="text-sm font-bold text-[--color-text] mb-3">{SITE.title}</p>
        <ContactBlock />
      </div>
      <div class="flex flex-col justify-between sm:items-end">
        <nav class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-[--color-text-muted]">
          <a href={url('/place')} class="hover:text-[--color-primary] transition-colors">Place</a>
          <a href={url('/learn')} class="hover:text-[--color-primary] transition-colors">Learn</a>
          <a href={url('/incubate')} class="hover:text-[--color-primary] transition-colors">Incubate</a>
          <a href={url('/exchange')} class="hover:text-[--color-primary] transition-colors">Exchange</a>
          <a href={url('/visit')} class="hover:text-[--color-primary] transition-colors">Visit</a>
          <a href={url('/blog')} class="hover:text-[--color-primary] transition-colors">Blog</a>
        </nav>
        <p class="mt-6 text-xs text-[--color-text-muted]">
          &copy; {year} {SITE.managedBy}. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
