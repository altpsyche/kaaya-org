---
import Base from './Base.astro';
import { formatDate } from '../lib/utils';

interface Props {
  title: string;
  pubDate: Date;
  description: string;
  heroImage?: string;
}

const { title, pubDate, description, heroImage } = Astro.props;
---

<Base {title} {description}>
  <article class="mx-auto max-w-2xl px-6 py-16">
    {heroImage && (
      <img
        src={heroImage}
        alt=""
        class="mb-8 aspect-video w-full rounded-xl object-cover"
        loading="eager"
      />
    )}
    <header class="mb-8">
      <time class="text-sm text-neutral-500" datetime={pubDate.toISOString()}>
        {formatDate(pubDate)}
      </time>
      <h1 class="mt-2 text-3xl font-bold text-neutral-900">{title}</h1>
      <p class="mt-3 text-lg text-neutral-600">{description}</p>
    </header>
    <div class="prose prose-neutral max-w-none">
      <slot />
    </div>
  </article>
</Base>
