---
import Base from './Base.astro';
import { formatDate } from '../lib/utils';
import { url } from '../lib/url';

interface Props {
  title: string;
  pubDate: Date;
  description: string;
  heroImage?: string;
  author?: string;
  readTime?: string;
}

const { title, pubDate, description, heroImage, author, readTime } = Astro.props;
---

<Base {title} {description}>
  <article class="mx-auto max-w-2xl px-6 py-16">
    {heroImage && (
      /* TODO: replace heroImage with self-hosted image */
      <img
        src={url(heroImage)}
        alt=""
        class="mb-8 aspect-video w-full rounded-xl object-cover"
        loading="eager"
      />
    )}
    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-2 text-sm text-[--color-text-muted]">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {author && <><span>·</span><span>By {author}</span></>}
        {readTime && <><span>·</span><span>{readTime}</span></>}
      </div>
      <h1 class="mt-3 text-3xl font-bold text-[--color-text]">{title}</h1>
      <p class="mt-3 text-lg text-[--color-text-muted]">{description}</p>
    </header>
    <div class="prose prose-neutral max-w-none">
      <slot />
    </div>
  </article>
</Base>
