---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found" noIndex>
  <div class="mx-auto max-w-4xl px-6 py-32 text-center">
    <p class="text-6xl font-bold text-neutral-200">404</p>
    <h1 class="mt-4 text-2xl font-semibold text-neutral-900">Page not found</h1>
    <p class="mt-2 text-neutral-600">The page you're looking for doesn't exist.</p>
    <a href="/" class="mt-8 inline-block text-sm font-medium text-primary hover:underline">
      ← Back home
    </a>
  </div>
</Base>
