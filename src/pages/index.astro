---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../lib/utils';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<Base>
  <section class="mx-auto max-w-4xl px-6 py-20">
    <h1 class="text-5xl font-bold text-neutral-900">Kaaya</h1>
    <p class="mt-4 text-xl text-neutral-600">A place of being.</p>
  </section>

  {posts.length > 0 && (
    <section class="mx-auto max-w-4xl px-6 pb-20">
      <h2 class="mb-8 text-2xl font-semibold text-neutral-900">Recent posts</h2>
      <ul class="space-y-6">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`} class="group block">
              <time class="text-sm text-neutral-500">
                {formatDate(post.data.pubDate)}
              </time>
              <h3 class="mt-1 text-lg font-medium text-neutral-900 group-hover:text-primary transition-colors">
                {post.data.title}
              </h3>
              <p class="mt-1 text-neutral-600">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
      <a href="/blog" class="mt-10 inline-block text-sm font-medium text-primary hover:underline">
        All posts →
      </a>
    </section>
  )}
</Base>
