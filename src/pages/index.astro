---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import Hero from '../components/ui/Hero.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import NavCard from '../components/ui/NavCard.astro';
import PostList from '../components/ui/PostList.astro';
import Button from '../components/ui/Button.astro';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const navCards = [
  {
    title: 'Place',
    description: 'Who we are, where we are, and what we are still learning',
    href: '/place',
  },
  {
    title: 'Learn',
    description: 'Programmes for those who want to learn alongside us',
    href: '/learn',
  },
  {
    title: 'Incubate',
    description: 'Ideas that need a place to grow — the Plug \'n\' Play model',
    href: '/incubate',
  },
  {
    title: 'Exchange',
    description: 'How we sustain ourselves and the neighbourhoods',
    href: '/exchange',
  },
  {
    title: 'Visit',
    description: 'Accommodation, rates, and how to find us',
    href: '/visit',
  },
];
---

<Base
  title="Kaaya Learning Centre — A small experiment in sustainable living"
  description="Kaaya Learning Centre is a mud-built campus in Tilwari, Dehradun where urban and rural communities meet, learn from each other, and find that the exchange is worth making."
>
  <Hero
    heading="It's about Re-imagining"
    subheading="Tilwari, Dehradun · Himalayan Foothills, India"
    cta={{ label: 'Learn about Kaaya', href: '/place' }}
  />

  <section class="mx-auto max-w-5xl px-6 py-16">
    <div class="max-w-2xl">
      <h2 class="text-xl font-semibold text-[--color-text]">A small experiment in sustainable living</h2>
      <p class="mt-4 leading-relaxed text-[--color-text-muted]">
        Kaaya Learning Centre is a mud-built campus in the village of Tilwari where urban and rural
        communities meet, learn from each other, and find that the exchange is worth making.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 pb-16">
    <SectionHeader title="What Kaaya is" />
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {navCards.map((card) => (
        <NavCard title={card.title} description={card.description} href={card.href} />
      ))}
    </div>
  </section>

  {recentPosts.length > 0 && (
    <section class="mx-auto max-w-5xl px-6 pb-20">
      <SectionHeader title="Latest from Kaaya" />
      <PostList posts={recentPosts} />
      <div class="mt-8">
        <Button href="/blog" label="View All Updates" variant="ghost" />
      </div>
    </section>
  )}
</Base>
