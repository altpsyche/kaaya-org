---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../lib/utils';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base title="Blog" description="All posts from Kaaya.">
  <div class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="mb-10 text-3xl font-bold text-neutral-900">Blog</h1>
    {posts.length === 0 ? (
      <p class="text-neutral-500">No posts yet. Check back soon.</p>
    ) : (
      <ul class="space-y-8">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`} class="group block">
              <time class="text-sm text-neutral-500">
                {formatDate(post.data.pubDate)}
              </time>
              <h2 class="mt-1 text-xl font-semibold text-neutral-900 group-hover:text-primary transition-colors">
                {post.data.title}
              </h2>
              <p class="mt-1 text-neutral-600">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Base>
