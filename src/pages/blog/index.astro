---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import CategoryFilter from '../../components/ui/CategoryFilter.astro';
import PostCard from '../../components/ui/PostCard.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const uniqueCats = [...new Set(posts.flatMap((p) => p.data.categories ?? []))].sort();
const categories = ['All Posts', ...uniqueCats];
---

<Base title="Blog" description="Stories, reflections, and updates from Kaaya Learning Centre.">
  <div class="mx-auto max-w-5xl px-6 py-16">
    <h1 class="mb-8 text-3xl font-bold text-[--color-text]">Blog</h1>

    {posts.length === 0 ? (
      <p class="text-[--color-text-muted]">No posts yet. Check back soon.</p>
    ) : (
      <>
        <CategoryFilter categories={categories} />
        <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <li
              data-post-item
              data-post-categories={post.data.categories?.join(',') ?? ''}
            >
              <PostCard
                title={post.data.title}
                description={post.data.description}
                href={`/blog/${post.id}`}
                pubDate={post.data.pubDate}
                heroImage={post.data.heroImage}
                author={post.data.author}
                readTime={post.data.readTime}
              />
            </li>
          ))}
        </ul>
      </>
    )}
  </div>
</Base>
